# .env.example — copy to .env for local dev. All vars use the MYAPP_ prefix
# (rewritten by bootstrap.sh). Config is validated on boot; missing/invalid
# required values fail fast.

# --- Server core ------------------------------------------------------------
MYAPP_ENV=dev                 # dev | prod
MYAPP_HTTP_HOST=127.0.0.1
MYAPP_HTTP_PORT=8080
MYAPP_LOG_LEVEL=debug         # debug | info | warn | error
# Dev-only: Go proxies unknown routes to the Vite dev server.
MYAPP_VITE_DEV_URL=http://127.0.0.1:5173

# --- Database ---------------------------------------------------------------
# Matches the docker-compose Postgres service. Validated on boot.
MYAPP_DB_DSN=postgres://myapp:myapp@127.0.0.1:5432/myapp?sslmode=disable

# --- Auth / OIDC ------------------------------------------------------------
# Defaults target the dev Dex IdP in docker-compose. Point these at your
# production OIDC provider. The client secret must match config/dex/config.yaml.
MYAPP_OIDC_ISSUER=http://127.0.0.1:5556/dex
MYAPP_OIDC_CLIENT_ID=myapp
MYAPP_OIDC_CLIENT_SECRET=myapp-dev-secret-change-me
MYAPP_OIDC_REDIRECT_URL=http://127.0.0.1:8080/auth/callback
MYAPP_OIDC_SCOPES=openid,profile,email
MYAPP_OIDC_POST_LOGOUT_REDIRECT_URL=http://127.0.0.1:8080/
MYAPP_SESSION_COOKIE_NAME=myapp_session
MYAPP_SESSION_COOKIE_DOMAIN=
MYAPP_SESSION_IDLE_TIMEOUT=30m
MYAPP_SESSION_ABSOLUTE_TIMEOUT=12h
# Must be at least 32 bytes. Generate a real random value in prod.
MYAPP_CSRF_SECRET=dev-csrf-secret-change-me-0123456789ab
